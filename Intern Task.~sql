--butun telebelerin siyahisi
select * from students;
--mueyyen muellimin kecdiyi dersler
select class_name from classes
where instructor_id=1;
--mueyyen telebenin yazildigi dersler
select class_name from classes
where class_id IN (select class_id from enrollments where student_id=1);--2den cox qiymet qaytardigi ucun evvelki = sehv verdi gererk IN yazasan
--mueyyen telebening butun qiymetleri
select grade_value from grades
where student_id=1;
--her ders uzre telebe sayi
select class_id, count(*) from enrollments group by class_id;
--her telebenin orta qiymeti
select avg(grade_value) from grades group by student_id;
--qiymeti 51den asagi olan telebeler
select student_id, grade_value from grades where grade_value<51;
--muellim+ders siyahisi join ile
select i.first_name||' '||i.last_name as name, 
       i.specialization, 
       i.email, 
       i.phone,
       i.hire_date,
       c.class_name,
       c.class_code,
       c.credit as cr,
       c.semester
  from instructors i,
       classes c
 where i.instructor_id=c.instructor_id;
--telebe+ders+qiymet birge hesabati
select s.first_name||' '||s.last_name as name,
       s.birth_date,
       s.gender,
       s.email,
       s.phone,
       c.class_name,
       c.class_code,
       c.credit as cr,
       c.semester,
       g.grade_value,
       g.grade_type
  from students s,
       classes c,
       grades g
 where g.student_id=s.student_id and g.class_id=c.class_id;
--en yuksek orta qiymete sahib telebeler
select student_id,avg(grade_value) as ortalama from grades group by student_id order by ortalama desc ;
